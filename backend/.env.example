# Server
PORT=3001
NODE_ENV=development
# Public URL used in logs/links (set this in production, e.g. Railway domain)
BACKEND_PUBLIC_URL=http://localhost:3001

# Google OAuth2 — create credentials at https://console.cloud.google.com/
# Application type: Web application
# Authorized redirect URI: http://localhost:3001/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# OpenAI — get key at https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Scan configuration
SCAN_START_DATE=2026/01/01
# Optional comma-separated hard blocklist for obvious non-job senders/domains
NON_JOB_SENDERS=
NON_JOB_SENDER_DOMAINS=

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:3000
